# Real translation workspaces — one folder per PDF you're post-editing.
# These hold user content (pages, original-page PNGs, per-PDF config) and
# never go to git. The framework's own apps/demo/ is the only sample that
# ships.
workspaces/

# Locally-installed developer skills (e.g. frontend-design installed via
