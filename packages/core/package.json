{
  "name": "@interlinear/core",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./config": {
      "types": "./dist/config.d.ts",
      "import": "./dist/config.js"
    },
    "./vite": {
      "types": "./dist/vite/index.d.ts",
      "import": "./dist/vite/index.js"
    },
    "./vite/client": "./src/vite/client.d.ts",
    "./styles/tokens.css": "./src/styles/tokens.css"
  },
  "files": [
    "dist",
    "skills",
    "src/styles",
    "src/vite/client.d.ts"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit",
    "prepack": "pnpm build"
  },
  "dependencies": {
    "@babel/parser": "^7.29.0",
    "@babel/types": "^7.29.0",
    "bundle-require": "^5.1.0",
    "fast-glob": "^3.3.2"
  },
  "peerDependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "vite": "^5.4.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "tsdown": "^0.9.9",
    "typescript": "^5.6.3",
    "vite": "^5.4.11"
  }
}
